# ── LLM (Groq) ──────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_key_here

# ── Research (Tavily) ────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_key_here
TAVILY_CACHE_TTL_HOURS=168

# ── ASR (Deepgram) ───────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_key_here

# ── TTS (ElevenLabs) ─────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here   # e.g. 21m00Tcm4TlvDq8ikWAM (Rachel)

# ── Dev flags ────────────────────────────────────────────────────────────────
# Set to 1 to run without external API calls (offline demo backup)
MOCK_ASR=0
MOCK_TTS=0

# ── Database ─────────────────────────────────────────────────────────────────
SQLITE_PATH=data/interview_coach.db

# ── App ──────────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Frontend (Next.js public vars) ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
